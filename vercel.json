{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/dashboard build && cp -r artifacts/dashboard/dist dist",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
